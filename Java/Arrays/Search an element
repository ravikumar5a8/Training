public class SearchElement {
    public static void main(String[] args) {
        int[] arr = {10, 20, 30, 40};
        int key = 30;

        boolean found = false;

        for (int num : arr) {
            if (num == key) {
                found = true;
                break;
            }
        }

        if (found)
            System.out.println("Element found");
        else
            System.out.println("Element not found");
    }
}
