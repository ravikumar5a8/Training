public class LargestElement {
    public static void main(String[] args) {
        int[] arr = {10, 20, 4, 45, 99};

        int largest = arr[0];

        for (int num : arr) {
            if (num > largest) {
                largest = num;
            }
        }

        System.out.println("Largest element: " + largest);
    }
}
